{
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@team-4/shadcn": ["libs/shadcn/src/index.ts"],
      "@team-4/shadcn/server": ["libs/shadcn/src/server.ts"]
    },
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@my-workspace/source"]
  }
}
